DATABASE_URL=postgresql://user:pass@localhost:5432/agora
OPENAI_API_KEY=sk-...
AGORA_API_URL=http://localhost:3000

# Public-facing URLs surfaced in OpenAPI spec, /.well-known/agora.json,
# adapter manifests, and the portal's CSP. Defaults to the Vercel auto-generated
# hostnames if unset — set these explicitly once custom domains are live.
AGORA_PUBLIC_URL=https://agora-ecru-chi.vercel.app
AGORA_PORTAL_URL=https://agora-portal.vercel.app
